<?xml version="1.0" encoding="utf-8"?>
<LevelObject identifier="latexbladder"
             name="Latex Bladder"
             description="A bioluminescent bulbous organism filled with a milky, elastic latex."
             category="Plant"
             tags="harvestable,plant"
             scale="1.0"
             canbefiredamaged="true"
             canbefrozen="true">

  <Sprite texture="Sprites/LatexBladder.png"
          depth="0.5"
          origin="0.5,0.0"
          offset="0,0" />

  <Physics shape="rectangle"
           width="32"
           height="32"
           bodytype="static"
           collisiontype="solid" />

  <!-- Harvest now drops the new item "latexbulb" -->
  <Harvestable identifier="latexbulb"
               minamount="1"
               maxamount="2"
               requiredtool="cutting"
               showremovedelay="15" />

  <!-- Optional: destroyed plant also drops the blob -->
  <Destructible health="20"
                minitemdropcount="1"
                maxitemdropcount="1"
                itemidentifier="latexbulb" />

  <Growable minsize="0.1"
            maxsize="1.0"
            growthspeed="0.02"
            requiredwater="1"
            requiredfertilizer="0"
            spritesheet="Sprites/LatexBladder_growth.png"
            spritesheetrows="1"
            spritesheetcolumns="2" />

  <SpriteState state="harvested"
               texture="Sprites/LatexBladder_harvested.png" />

  <BiomeSpawns>
    <BiomeSpawn biome="hydrothermalvents"
                spawntype="wall"
                minspawns="2"
                maxspawns="5"
                spawnprobability="0.3" />
    <BiomeSpawn biome="abyss"
                spawntype="wall"
                minspawns="1"
                maxspawns="3"
                spawnprobability="0.2" />
  </BiomeSpawns>

  <Sound file="Content/Sounds/harvest_plant.ogg" type="OnHarvest" />
</LevelObject>
